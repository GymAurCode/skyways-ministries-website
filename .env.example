# ─── MongoDB Atlas (Required) ──────────────────────────────────────────────────
# Note: Our database configuration automatically handles, parses, and URL-encodes 
# any special characters (like !, @, #, etc.) in your password at runtime.
# Format: mongodb+srv://<username>:<password>@<host>/<database>
MONGODB_URI=mongodb+srv://your_db_username:your_db_password@cluster0.xxxxxx.mongodb.net/skywayDB?retryWrites=true&w=majority

# ─── JWT Authentication (Required) ────────────────────────────────────────────
# Must be a secure random key of at least 32 characters in production
JWT_SECRET=replace_with_at_least_32_random_characters_secret_key
JWT_EXPIRES=7d

# ─── Admin Seed Credentials (Used by: npm run seed) ───────────────────────────
# Fallback defaults for database initialization (minimum 8 characters, 1 letter, 1 number)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin123

# ─── Cloudinary Integrations (Optional for image uploads) ──────────────────────
# CLOUDINARY_CLOUD_NAME=your_cloudinary_cloud_name
# CLOUDINARY_API_KEY=your_cloudinary_api_key
# CLOUDINARY_API_SECRET=your_cloudinary_api_secret

# ─── Local Port Configuration (Optional) ───────────────────────────────────────
PORT=3000
