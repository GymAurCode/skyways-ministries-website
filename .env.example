# MongoDB (required for API + seed)
MONGODB_URI=mongodb+srv://USER:PASS@cluster.example.mongodb.net/skyway?retryWrites=true&w=majority

# Admin seed (run: npm run seed) — example meets policy: 8+ chars, letter + number
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin123

# JWT for admin sessions (required in production — min 32 chars)
JWT_SECRET=replace_with_at_least_32_random_characters_secret_key

# Optional: Cloudinary for image uploads (gallery, logos, testimonials)
# CLOUDINARY_CLOUD_NAME=
# CLOUDINARY_API_KEY=
# CLOUDINARY_API_SECRET=

# Local Vite: proxy /api to Vercel dev server (npm i -g vercel && vercel dev)
# VITE_API_URL=http://127.0.0.1:3000
